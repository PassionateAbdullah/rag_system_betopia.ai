# QDRANT_COLLECTION=betopia_rag_mvp

# # Embeddings
# # provider: "sentence-transformers" (local) or "http" (OpenAI-compatible API)
# EMBEDDING_PROVIDER=sentence-transformers
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# # Vector size must match the chosen model. bge-m3 = 1024, bge-small-en-v1.5 = 384, jina-embeddings-v3 = 1024
# EMBEDDING_DIM=1024

# # Defaults
# RAG_WORKSPACE_ID=default
# RAG_RETRIEVE_TOP_K=10
# RAG_FINAL_MAX_CHUNKS=5
# RAG_MAX_TOKENS=4000
# RAG_CHUNK_SIZE=500
# RAG_CHUNK_OVERLAP=80




# Qdrant Cloud
QDRANT_URL=https://81449aec-2d04-46c4-a028-a0fe1f42fd5c.sa-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=YOUR_NEW_QDRANT_API_KEY
QDRANT_COLLECTION=betopia_rag_mvp

# Embeddings
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# Defaults
RAG_WORKSPACE_ID=default
RAG_RETRIEVE_TOP_K=10
RAG_FINAL_MAX_CHUNKS=3
RAG_MAX_TOKENS=4000
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80

# API server
RAG_API_HOST=0.0.0.0
RAG_API_PORT=8080
# If set, every request must send X-API-Key: <value>. Unset = open (dev only).
RAG_API_KEY=
# Comma-separated origins, or "*". Default "*" for dev.
RAG_API_CORS_ORIGINS=*
# Max upload size in MB.
RAG_API_MAX_UPLOAD_MB=50

# Query rewriter
# "rules" (default, free, deterministic) or "llm" (uses OpenAI-compatible chat
# endpoint to polish chatty questions into terse retrieval queries).
# When QUERY_REWRITER=llm, BASE_URL + MODEL must be set; API_KEY is optional
# (some local servers don't require it). On any LLM error, the system falls
# back to the rules-based rewrite — retrieval never blocks.
QUERY_REWRITER=rules
QUERY_REWRITER_MODEL=
QUERY_REWRITER_BASE_URL=
QUERY_REWRITER_API_KEY=
QUERY_REWRITER_TIMEOUT=5.0
