# =============================================================================
# Betopia RAG — environment variables
# Two modes:
#   1. MVP / Qdrant-only (POSTGRES_URL unset) — works on the existing CLI/UI/API.
#   2. Production (POSTGRES_URL set) — enables hybrid retrieval, candidate
#      expansion, full ingestion dual-write to Postgres + Qdrant.
# =============================================================================

# ---------- Vector store ----------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=betopia_rag_mvp

# ---------- Postgres (canonical chunk store + keyword search) ----------
# Unset = MVP/Qdrant-only mode. Production / hybrid: set this.
# Default matches docker-compose.yml.
POSTGRES_URL=postgresql://rag:rag@localhost:5432/betopia_rag

# ---------- Embeddings ----------
# Default: BAAI/bge-m3 — local, free, multilingual, 1024 dim, 8K ctx.
# Downloads ~567 MB on first run; reused after.
#
# Provider switch:
#   "sentence-transformers" — local model (default below)
#   "http"                  — OpenAI-compatible /embeddings endpoint
#                             (OpenAI, Jina, Voyage, Ollama, TEI, vLLM)
#
# Faster hosted alternatives (set EMBEDDING_PROVIDER=http):
#   Jina      EMBEDDING_BASE_URL=https://api.jina.ai/v1   MODEL=jina-embeddings-v3   DIM=1024
#   OpenAI    EMBEDDING_BASE_URL=https://api.openai.com/v1 MODEL=text-embedding-3-small DIM=1536
#   Ollama    EMBEDDING_BASE_URL=http://localhost:11434/v1 MODEL=nomic-embed-text     DIM=768
#   TEI       EMBEDDING_BASE_URL=http://localhost:8088/v1  MODEL=BAAI/bge-m3          DIM=1024
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
# Must match what the model returns. Drop the Qdrant collection if you change this.
# bge-m3=1024, text-embedding-3-small=1536, jina-embeddings-v3=1024,
# nomic-embed-text=768, bge-small-en-v1.5=384.
EMBEDDING_DIM=1024

# ---------- RAG defaults ----------
RAG_WORKSPACE_ID=default
RAG_RETRIEVE_TOP_K=20
RAG_FINAL_MAX_CHUNKS=8
RAG_MAX_TOKENS=4000
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100

# ---------- PDF loader ----------
# Loader chain (auto): pymupdf → pdfplumber → pypdf → markitdown.
#   pymupdf      — fastest, layout-aware. AGPL.
#   pdfplumber   — good for tables, slower than pymupdf. MIT.
#   pypdf        — pure Python, slowest of fast three. BSD.
#   markitdown   — last-resort, 10–100× slower on big PDFs.
PDF_LOADER=auto

# ---------- Chunker ----------
# "auto"         — per-document selection: short=word, narrative PDF=semantic,
#                  structured docs=hierarchical parent/child.
# "word"         — fixed N-word window with overlap. Free, deterministic.
# "semantic"     — sentence-embed boundaries. Costs extra embed calls per
#                  ingest; recall typically up 5–15%.
# "hierarchical" — child chunks for retrieval + parent context for the agent.
#                  No extra embed cost; index doubles in storage size.
CHUNKER=auto

# ---------- Hybrid retrieval ----------
DEFAULT_KEYWORD_TOP_K=30
DEFAULT_VECTOR_TOP_K=30
DEFAULT_MERGED_CANDIDATE_LIMIT=50
DEFAULT_RERANK_TOP_K=20
# Used by the no-Postgres lexical leg. It scans Qdrant payload text locally,
# then merges those BM25-style hits with vector hits.
QDRANT_KEYWORD_SCAN_LIMIT=5000

# ---------- API server ----------
RAG_API_HOST=0.0.0.0
RAG_API_PORT=8080
# If set, every request must send X-API-Key: <value>. Unset = open (dev only).
RAG_API_KEY=
RAG_API_CORS_ORIGINS=*
RAG_API_MAX_UPLOAD_MB=50

# ---------- Query rewriter ----------
# "rules" (default) or "llm" (OpenAI-compatible chat endpoint).
# When QUERY_REWRITER=llm, BASE_URL + MODEL must be set; on any error the
# system falls back to rules — retrieval never blocks.
QUERY_REWRITER=rules
QUERY_REWRITER_MODEL=
QUERY_REWRITER_BASE_URL=
QUERY_REWRITER_API_KEY=
QUERY_REWRITER_TIMEOUT=5.0

# ---------- Reranker ----------
# "fallback" (weighted vector + keyword + metadata, no extra deps),
# "cross-encoder" (sentence-transformers CrossEncoder, e.g. bge-reranker-large),
# "jina" or "qwen" (HTTP API).
RERANKER_PROVIDER=fallback
RERANKER_MODEL=
RERANKER_API_KEY=
RERANKER_BASE_URL=
RERANKER_TIMEOUT=10.0

# ---------- Context compression ----------
# "extractive" (default — sentence-level, free), "llm" (OpenAI-compatible
# chat), or "noop" (skip).
COMPRESSION_PROVIDER=extractive
COMPRESSION_MODEL=
COMPRESSION_API_KEY=
COMPRESSION_BASE_URL=
COMPRESSION_TIMEOUT=15.0

# ---------- Contextual retrieval (Anthropic, Sept 2024) ----------
# When enabled, ingestion runs a small LLM (Haiku-class) over each chunk
# to generate a 1-2 sentence preamble that situates the chunk inside its
# document. The preamble is prepended only at embed time so the agent
# still sees the original chunk text. Cached on disk by content hash so
# re-ingesting the same document costs nothing.
# Off by default: leave ENABLE_CONTEXTUAL_RETRIEVAL=false until an LLM
# endpoint + key are configured.
CONTEXTUALIZER_MODEL=
CONTEXTUALIZER_API_KEY=
CONTEXTUALIZER_BASE_URL=
CONTEXTUALIZER_TIMEOUT=20.0
CONTEXTUALIZER_CONCURRENCY=8
CONTEXTUALIZER_DOC_EXCERPT_CHARS=2400
CONTEXTUALIZER_CACHE_DIR=.cache/contextualizer

# ---------- Feature flags ----------
ENABLE_QUERY_REWRITE=true
ENABLE_QUERY_UNDERSTANDING=true
ENABLE_HYBRID_RETRIEVAL=true
ENABLE_ADAPTIVE_CHUNKING=true
ENABLE_CANDIDATE_EXPANSION=false
ENABLE_CONTEXT_COMPRESSION=true
ENABLE_CONTEXTUAL_RETRIEVAL=false
ENABLE_DEBUG_LOGGING=false
ENABLE_EVAL_LOG=false
EVAL_LOG_PATH=logs/eval.jsonl

# ---------- Candidate expansion ----------
NEIGHBOR_CHUNK_WINDOW=1
INCLUDE_PARENT_SECTION=true
