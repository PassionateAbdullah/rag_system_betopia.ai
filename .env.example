# =============================================================================
# Betopia RAG — environment variables
# Two modes:
#   1. MVP / Qdrant-only (POSTGRES_URL unset) — works on the existing CLI/UI/API.
#   2. Production (POSTGRES_URL set) — enables hybrid retrieval, candidate
#      expansion, full ingestion dual-write to Postgres + Qdrant.
# =============================================================================

# ---------- Vector store ----------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=betopia_rag_mvp

# ---------- Postgres (canonical chunk store + keyword search) ----------
# Unset = MVP/Qdrant-only mode. Production: set this to enable hybrid.
# POSTGRES_URL=postgresql://rag:rag@localhost:5432/betopia_rag
POSTGRES_URL=

# ---------- Embeddings ----------
# provider: "sentence-transformers" (local) or "http" (OpenAI-compatible API)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
# bge-m3 = 1024, bge-small-en-v1.5 = 384, jina-embeddings-v3 = 1024
EMBEDDING_DIM=1024

# ---------- RAG defaults ----------
RAG_WORKSPACE_ID=default
RAG_RETRIEVE_TOP_K=20
RAG_FINAL_MAX_CHUNKS=8
RAG_MAX_TOKENS=4000
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100

# ---------- Hybrid retrieval ----------
DEFAULT_KEYWORD_TOP_K=30
DEFAULT_VECTOR_TOP_K=30
DEFAULT_MERGED_CANDIDATE_LIMIT=50
DEFAULT_RERANK_TOP_K=20

# ---------- API server ----------
RAG_API_HOST=0.0.0.0
RAG_API_PORT=8080
# If set, every request must send X-API-Key: <value>. Unset = open (dev only).
RAG_API_KEY=
RAG_API_CORS_ORIGINS=*
RAG_API_MAX_UPLOAD_MB=50

# ---------- Query rewriter ----------
# "rules" (default) or "llm" (OpenAI-compatible chat endpoint).
# When QUERY_REWRITER=llm, BASE_URL + MODEL must be set; on any error the
# system falls back to rules — retrieval never blocks.
QUERY_REWRITER=rules
QUERY_REWRITER_MODEL=
QUERY_REWRITER_BASE_URL=
QUERY_REWRITER_API_KEY=
QUERY_REWRITER_TIMEOUT=5.0

# ---------- Reranker ----------
# "fallback" (weighted vector + keyword + metadata, no extra deps),
# "cross-encoder" (sentence-transformers CrossEncoder, e.g. bge-reranker-large),
# "jina" or "qwen" (HTTP API).
RERANKER_PROVIDER=fallback
RERANKER_MODEL=
RERANKER_API_KEY=
RERANKER_BASE_URL=
RERANKER_TIMEOUT=10.0

# ---------- Context compression ----------
# "extractive" (default — sentence-level, free), "llm" (OpenAI-compatible
# chat), or "noop" (skip).
COMPRESSION_PROVIDER=extractive
COMPRESSION_MODEL=
COMPRESSION_API_KEY=
COMPRESSION_BASE_URL=
COMPRESSION_TIMEOUT=15.0

# ---------- Feature flags ----------
ENABLE_QUERY_REWRITE=true
ENABLE_QUERY_UNDERSTANDING=true
ENABLE_HYBRID_RETRIEVAL=true
ENABLE_CANDIDATE_EXPANSION=false
ENABLE_CONTEXT_COMPRESSION=true
ENABLE_DEBUG_LOGGING=false
ENABLE_EVAL_LOG=false
EVAL_LOG_PATH=logs/eval.jsonl

# ---------- Candidate expansion ----------
NEIGHBOR_CHUNK_WINDOW=1
INCLUDE_PARENT_SECTION=true
