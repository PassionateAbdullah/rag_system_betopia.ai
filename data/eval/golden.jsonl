# Golden eval set — JSONL, one item per line. Lines starting with '#' or blank are ignored.
# Schema:
#   {"id": str, "query": str, "workspaceId"?: str,
#    "expectedSourceIds"?: [str], "expectedSubstrings"?: [str],
#    "tags"?: [str], "notes"?: str}
# A retrieved chunk = relevant if its sourceId is in expectedSourceIds OR any
# expectedSubstring is a substring of chunk.text (case-insensitive).
#
# Seed examples below are based on the bangladesh-dengue test doc.
# Add 30-50 entries spanning your real corpus before trusting metrics.
{"id": "dengue-2023-peak-month", "query": "what was the peak month for dengue in bangladesh 2023", "workspaceId": "default", "expectedSubstrings": ["September 2023", "79,598"], "tags": ["numeric", "table", "dates"], "notes": "Peak = Sept 2023, 79,598 cases."}
